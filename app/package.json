{
  "name": "gui-lhaddas",
  "version": "1.1.0",
  "description": "GUI for LHADDAS",
  "main": "./out/main/index.js",
  "author": "JAEA",
  "license": "MIT",
  "homepage": "",
  "scripts": {
    "prebuild:win": "rimraf dist out",
    "prebuild:win:no-typecheck": "rimraf dist out",
    "prebuild:mac": "rimraf dist out",
    "prebuild:linux": "rimraf dist out",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --watch",
    "build:no-typecheck": "electron-vite build",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:win:no-typecheck": "npm run build:no-typecheck && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.1.8",
    "@mui/material": "^6.5.0",
    "cesium": "^1.123.1",
    "fast-glob": "^3.3.3",
    "i18next": "^25.4.2",
    "jotai": "^2.10.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.7.2",
    "resium": "1.17.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.0",
    "rimraf": "^1.0.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-cesium": "^1.2.23"
  }
}
